**SDevice Code(Id-Vgs)**
File {
   Grid= "@tdr@"
   Parameter="@parameter@"
   Plot= "@tdrdat@"
   Current="@plot@"
   Output= "@log@"
}

Electrode {
   { Name= "s" Voltage= 0.0 Resistor= 40 }
   { Name= "d" Voltage= 0.0 Resistor= 40 }
   { Name= "g" Voltage= 0.0 WorkFunction=4.45 }
}

Physics{
   Fermi
   AreaFactor=1.0
}

Physics(Material= "Silicon"){
   eQuantumPotential hQuantumPotential
   EffectiveIntrinsicDensity(OldSlotboom)
   Mobility(
      DopingDep
      HighFieldSaturation
      Enormal(IALMob(AutoOrientation))
   )
   Recombination(
      SRH(DopingDep TempDependence)
   )
}

Plot{
   eDensity hDensity
   TotalCurrent/Vector eCurrent/Vector hCurrent/Vector
   eMobility hMobility
   eVelocity hVelocity
   eQuasiFermi hQuasiFermi
   eTemperature Temperature hTemperature
   ElectricField/Vector Potential SpaceCharge
   Doping DonorConcentration AcceptorConcentration
   SRH Band2Band
   eGradQuasiFermi/Vector hGradQuasiFermi/Vector
   eEparallel hEparallel eENormal hENormal
   BandGap
   BandGapNarrowing
   Affinity
   ConductionBand ValenceBand
   eQuantumPotential hQuantumPotential
}

Math {
  Extrapolate
  Derivatives
  Avalderivatives
  RelErrControl
  Digits=6
  ErrRef(electron)= 1.e10
  ErrRef(hole)= 1.e10
  Notdamped= 50
  Iterations= 50
  Method= ILS
}

Solve {

   Coupled(Iterations=100 LineSearchDamping=1e-4)
   { Poisson eQuantumPotential hQuantumPotential }

   Coupled(Iterations=100 LineSearchDamping=1e-4)
   { Poisson Electron Hole eQuantumPotential hQuantumPotential }

   Quasistationary(
      InitialStep=0.01 Increment=1.3
      MinStep=1e-5 MaxStep=0.02
      Goal { Name="d" Voltage=0.05 }
   ){
      Coupled { Poisson Electron Hole eQuantumPotential hQuantumPotential }
   }

   NewCurrentPrefix="IdVg_"

   Quasistationary(
      DoZero
      InitialStep=0.01 Increment=1.3 Decrement=2
      MinStep=1e-5 MaxStep=0.02
      Goal { Name="g" Voltage=1.0 }
   ){
      Coupled { Poisson Electron Hole eQuantumPotential hQuantumPotential }
      CurrentPlot(
         Time=(Range=(0 1) Intervals=60)
      )
   }
}


